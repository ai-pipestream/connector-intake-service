# Copy to .env.local or pass with ENV_FILE=/path/to/file.
# Do not commit local env files containing API keys, hostnames, or local paths.

# Service endpoints.
SERVICE_HOST=localhost
INTAKE_HTTP_PORT=18108
ACCOUNT_PORT=18105
REPO_PORT=18102
ADMIN_PORT=18107

# Existing datasource credentials. If both are set, prepare-datasource.sh reuses them.
DS_ID=
API_KEY=

# Used only when DS_ID/API_KEY are empty and prepare-datasource.sh creates a sample datasource.
ACCOUNT_ID=sample-account
DRIVE_NAME=sample-drive
LOCAL_BUCKET=pipestream
DATASOURCE_NAME=sample-http-upload
CONNECTOR_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11

# Upload source. Set one or both locally.
INTAKE_E2E_SOURCE_FILE=/path/to/one/document.pdf
INTAKE_E2E_SOURCE_DIR=/path/to/document/directory

# Optional upload metadata.
INTAKE_E2E_SOURCE_PREFIX=e2e/http-upload
INTAKE_E2E_CONTENT_TYPE=application/octet-stream
INTAKE_E2E_MAX_FILES=0
